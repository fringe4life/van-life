    "@cloudflare/vite-plugin": "1.45.1",
    "@cloudflare/workers-types": "^5.20260719.1",
    "@fontsource-variable/inter": "^5.3.0",
    "@react-router/dev": "8.2.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.3",
    "@types/babel__core": "^7.20.5",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@varlock/cloudflare-integration": "^1.3.0",
    "@vitejs/devtools": "^0.4.1",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "drizzle-kit": "1.0.0-rc.4",
    "fallow": "3.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "react-doctor": "^0.8.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.3.3",
    "typescript": "^7.0.2",
    "ultracite": "7.9.4",
    "vite": "8.1.5",
    "wrangler": "^4.112.0"
  },
  "name": "van-life",
  "scripts": {
    "analyze": "VITE_ANALYZE=true varlock run -- react-router build",
    "build": "varlock run -- react-router build",
    "devtools": "varlock run -- vite-devtools",
    "deploy:project": "varlock-wrangler deploy",
    "deploy:upload": "varlock-wrangler versions upload",
    "deploy:versions": "varlock-wrangler versions deploy",
    "dev": "varlock run -- react-router dev",
    "preview": "varlock run -- vite preview",
    "typegen": "varlock-wrangler types && react-router typegen",
    "typecheck": "bun run typegen && tsc",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "bun run scripts/flatten-d1-migrations.ts && wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "bun run scripts/flatten-d1-migrations.ts && wrangler d1 migrations apply DB --remote",
    "db:optimize:local": "wrangler d1 execute DB --local --command='PRAGMA optimize'",
    "db:optimize:remote": "wrangler d1 execute DB --remote --command='PRAGMA optimize'",
    "db:seed": "bun run app/db/seed.ts",
    "db:seed:remote": "varlock run -- bun run app/db/seed.ts --remote",
    "db:studio:local": "drizzle-kit studio --config drizzle.local.config.ts",
    "db:studio:remote": "varlock run -- drizzle-kit studio",
    "fix": "ultracite fix",
    "check": "ultracite check",
    "doctor": "ultracite doctor",
    "ultracite:upgrade": "bun x ultracite@latest init --pm bun --linter biome --agents cursor-cli --editors cursor --hooks cursor --frameworks remix --quiet",
    "react-doctor": "react-doctor",
    "fallow": "fallow",
    "fallow:audit": "fallow audit",
    "prepare": "husky",
    "test": "bun test"
  },
  "type": "module",
  "private": true,
  "trustedDependencies": [],
  "overrides": {}
}
