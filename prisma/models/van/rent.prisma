model Rent {
  id           String        @id @default(uuid(7)) @db.Uuid
  renterId     String        @db.Uuid
  hostId       String        @db.Uuid
  rentedAt     DateTime      @default(now()) @db.Date
  rentedTo     DateTime?     @db.Date
  vanId        String        @db.Uuid
  host         User          @relation("host", fields: [hostId], references: [id])
  renter       User          @relation("renter", fields: [renterId], references: [id])
  van          Van           @relation(fields: [vanId], references: [id])
  reviews      Review[]
  transactions Transaction[]

  @@index([rentedTo])
  @@index([vanId])
  @@index([renterId])
  @@index([hostId])
  @@index([renterId, rentedTo])
  @@index([hostId, rentedTo])
}
